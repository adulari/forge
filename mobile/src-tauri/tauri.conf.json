{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Forge",
  "version": "2.5.8",
  "identifier": "dev.adulari.forge",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:8081",
    "beforeDevCommand": "",
    "beforeBuildCommand": "npx expo export -p web"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Forge",
        "width": 1180,
        "height": 800,
        "minWidth": 380,
        "minHeight": 640,
        "titleBarStyle": "Overlay",
        "backgroundColor": "#131318"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIwMTA0RENGOTkzQTA4QTAKUldTZ0NEcVp6MDBRSUtyZFVwWmVTbmMwWHlkMFZMelo4NVp3cHEzY21RRGNZMFdzZms3Mk5ESFAK",
      "endpoints": ["https://github.com/Adulari/forge/releases/latest/download/latest.json"]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb", "dmg", "nsis", "app"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "infoPlist": "Info.plist"
    }
  }
}
