# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

# generated native folders — /android stays fully generated (no Android CI yet).
# ios/ is committed as an Xcode Cloud bootstrap: Xcode Cloud needs a real
# .xcodeproj/.xcworkspace in the repo just to let you create a workflow at all.
# ci_scripts/ci_post_clone.sh regenerates it fresh from app.config on every real
# build, so the committed copy only has to be "good enough to exist" — see
# ios/ci_scripts/ci_post_clone.sh.
/android
ios/Pods/
ios/build/
ios/DerivedData/
ios/*.xcuserstate
ios/**/xcuserdata/

# @bacons/apple-targets writes these into the target source dir at prebuild
# time (alongside the hand-authored Swift files, which ARE committed).
targets/*/Info.plist
targets/*/generated.entitlements
targets/*/Assets.xcassets

# Tauri (mobile/src-tauri/)
src-tauri/target/
src-tauri/gen/
