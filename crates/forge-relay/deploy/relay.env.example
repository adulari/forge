FORGE_APNS_TEAM_ID=YOUR_TEAM_ID
FORGE_APNS_KEY_ID=YOUR_APNS_KEY_ID
FORGE_RELAY_BIND_ADDR=127.0.0.1
FORGE_RELAY_TRUST_PROXY_HEADERS=true
# Required privacy mode for the stock public relay. Private relays omit this (or set false) to
# preserve rich notification text.
FORGE_RELAY_GENERIC_ALERTS=true
PORT=8787
FORGE_RELAY_RATE_LIMIT=30
FORGE_RELAY_RATE_WINDOW_SECS=60
FORGE_RELAY_DAILY_SEND_CAP=50000
