# Rust
/target
**/*.rs.bk
*.pdb
Cargo.lock.orig

# Forge local state / secrets — never commit
*.env
.env
.env.*
*.p8
*.pem
*.key
*.p12
/.forge
forge.db
forge.db-*
*.sqlite
*.sqlite-*

# Editor / OS
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# Diagrams: keep .puml sources, ignore local renders unless committed deliberately
docs/architecture/**/*.tmp.png
graphify-out/

# Stray nested forge runtime dirs (root /.forge already ignored above)
**/.forge/
.dual-graph/

# E2E battery scratch output (scripts/e2e-battery.sh)
scripts/.e2e-out/

# Curated manual E2E run output (scripts/manual-e2e/run.sh)
scripts/.manual-e2e-out/

# Container-built E2E binary target dir (scripts/e2e-docker.sh)
target-e2e/

# Demo recording stage (scripts/demo/setup.sh)
scripts/demo/.stage/

# Local cargo config (absolute target-dir etc.) must never be committed
.cargo/
